{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "NEAR Docs",
  "colors": {
    "primary": "#1fb858",
    "light": "#1fb858",
    "dark": "#1fb858"
  },
  "logo": {
    "light": "/assets/logo.svg",
    "dark": "/assets/logo_rev.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/near"
      }
    ]
  },
  "search": {
    "prompt": "Search docs..."
  },
  "contextual": {
    "options": [
      "copy",
      "claude",
      "cursor"
    ]
  },
  "interaction": {
    "drilldown": true
  },
  "favicon": "assets/favicon.svg",
  "api": {
    "openapi": "/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "bash",
        "javascript",
        "python"
      ],
      "defaults": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": " ",
        "groups": [
          {
            "group": " ",
            "pages": [
              "/index",
              "protocol/basics",
              "create-account",
              "faucet",
              "tools-for-ai"
            ]
          }
        ]
      },
