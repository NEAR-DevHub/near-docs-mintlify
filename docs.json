{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "NEAR Docs",
  "colors": {
    "primary": "#3b82f6",
    "light": "#3b82f6",
    "dark": "#3b82f6"
  },
  "logo": {
    "light": "/assets/logo.svg",
    "dark": "/assets/logo_rev.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/near"
      }
    ]
  },
  "search": {
    "prompt": "Search docs..."
  },
  "contextual": {
    "options": ["copy", "claude", "cursor"]
  },
  "interaction": {
    "drilldown": true
  },
  "favicon": "assets/favicon.svg",
